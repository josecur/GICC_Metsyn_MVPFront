# Fuente de datos del dashboard.
#   mock     → datos en memoria (números reales del spec). Por defecto.
#   supabase → consulta la tabla `registros` en Supabase.
VITE_DATA_SOURCE=mock

# Credenciales Supabase. Rellenar cuando tengas acceso y luego poner
# VITE_DATA_SOURCE=supabase para usar datos reales sin tocar la UI.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
